# Example Environment Variables

# Database URL
DATABASE_URL=postgres://user:password@localhost:5432/attendance_db

# Secret Key
SECRET_KEY=your-secret-key

# Debug Mode
DEBUG=True

# Allowed Hosts
ALLOWED_HOSTS=localhost, 127.0.0.1

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://yourdomain.com

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=7 days